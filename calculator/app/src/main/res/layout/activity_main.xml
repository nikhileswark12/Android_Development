<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <!-- DISPLAY -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/display_background"
        android:text="0"
        android:textColor="#000000"
        android:textSize="36sp"
        android:gravity="end|center_vertical"
        android:paddingEnd="16dp" />

    <!-- CLEAR ENTRY + OPERATOR COLUMN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <!-- CLEAR ENTRY -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:text="CLEAR ENTRY"
            style="@style/CalculatorButtonClear" />

        <!-- OPERATOR COLUMN -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/operators_panel"
            android:padding="8dp"
            android:layout_marginStart="12dp">

            <Button
                android:id="@+id/btnAdd"
                android:text="+"
                style="@style/CalculatorButtonOperator" />

            <Button
                android:id="@+id/btnSubtract"
                android:text="-"
                style="@style/CalculatorButtonOperator" />

            <Button
                android:id="@+id/btnMultiply"
                android:text="*"
                style="@style/CalculatorButtonOperator" />

            <Button
                android:id="@+id/btnDivide"
                android:text="/"
                style="@style/CalculatorButtonOperator" />
        </LinearLayout>
    </LinearLayout>

    <!-- NUMBER PAD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/numbers_panel"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        android:paddingBottom="32dp">

        <!-- Row 1 -->
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btn0" android:text="0" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn1" android:text="1" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn2" android:text="2" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn3" android:text="3" style="@style/CalculatorButtonNumber" />
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btn4" android:text="4" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn5" android:text="5" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn6" android:text="6" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn7" android:text="7" style="@style/CalculatorButtonNumber" />
        </LinearLayout>

        <!-- Row 3 -->
        <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
            <Button android:id="@+id/btn8" android:text="8" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btn9" android:text="9" style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btnDecimal" android:text="." style="@style/CalculatorButtonNumber" />
            <Button android:id="@+id/btnEquals" android:text="=" style="@style/CalculatorButtonEquals" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
